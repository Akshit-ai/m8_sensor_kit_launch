<launch>
  <!-- 
       lidar.launch.xml
       Ouster OS1-128  ->  ouster_ros driver  ->  pointcloud_preprocessor

       Topic flow:
         ouster_ros driver
           -> /ouster/points  (sensor_msgs/PointCloud2, frame: ouster_top)
           -> remapped to /sensing/lidar/top/pointcloud_raw
           -> pointcloud_preprocessor.launch.py
           -> /sensing/lidar/top/pointcloud  (Autoware contract)

       Key lessons from Autoware community (github.com/autowarefoundation/
       autoware_universe/issues/4978):
         - lidar_frame MUST be "ouster_top" to match URDF/calibration
         - point_cloud_frame must match lidar_frame
         - TF timeout occurs if frame names don't match between driver and URDF
   -->

  <!--  Arguments  -->

  <!-- Ouster sensor IP on vehicle network (from driver_config.yaml) -->
  <arg name="ouster_ip"       default="10.1.14.10"/>

  <!-- LiDAR frame ID - MUST match ouster_lidar_base_link in calibration yaml
       and MUST match what pointcloud_preprocessor expects -->
  <arg name="lidar_frame_id"  default="ouster_top"/>

  <!-- Base frame for transforms -->
  <arg name="base_frame"      default="base_link"/>

  <!-- Resolution and scan rate (from driver_config.yaml: 1024x10) -->
  <arg name="lidar_mode"      default="1024x10"/>

  <!-- Timestamp mode (from driver_config.yaml: PTP sync) -->
  <arg name="timestamp_mode"  default="TIME_FROM_PTP_1588"/>

  <!-- ouster_ros driver
       Official Ouster ROS2 driver (github.com/ouster-lidar/ouster-ros)
       Publishes /ouster/points as sensor_msgs/PointCloud2

       Important: lidar_frame and point_cloud_frame MUST be "ouster_top"
       to match our sensor_kit_calibration.yaml and URDF transforms.
   -->
  <group>
    <push-ros-namespace namespace="ouster"/>

    <node pkg="ouster_ros" exec="os_driver" name="os_driver" output="screen">
      <!-- Network -->
      <param name="sensor_hostname"      value="$(var ouster_ip)"/>

      <!-- Scan resolution and rate -->
      <param name="lidar_mode"           value="$(var lidar_mode)"/>

      <!-- Frame IDs - must match URDF/calibration -->
      <param name="sensor_frame"         value="os_sensor"/>
      <param name="lidar_frame"          value="$(var lidar_frame_id)"/>
      <param name="imu_frame"            value="os_imu"/>
      <param name="point_cloud_frame"    value="$(var lidar_frame_id)"/>

      <!-- Timestamp: PTP sync (from driver_config.yaml) -->
      <param name="timestamp_mode"       value="$(var timestamp_mode)"/>
      <param name="ptp_utc_tai_offset"   value="-37.0"/>

      <!-- Only enable pointcloud (PCL) - IMU handled by iNAT M300 -->
      <param name="proc_mask"            value="PCL"/>

      <!-- QoS: system default needed for rosbag compatibility -->
      <param name="use_system_default_qos" value="true"/>

      <!-- Remap ouster output to Autoware standard topic -->
      <remap from="ouster/points" to="/sensing/lidar/top/pointcloud_raw"/>
    </node>

    <!-- Lifecycle management: configure then activate the driver node -->
    <executable
      cmd="ros2 lifecycle set /ouster/os_driver configure"
      launch-prefix="bash -c 'sleep 1; $0 $@'"
      output="screen"/>
    <executable
      cmd="ros2 lifecycle set /ouster/os_driver activate"
      launch-prefix="bash -c 'sleep 2; $0 $@'"
      output="screen"/>

  </group>

  <!-- ── pointcloud_preprocessor 
       5-stage pipeline: crop -> distortion correct -> outlier filter
       -> downsample -> transform to base_link

       Input:  /sensing/lidar/top/pointcloud_raw
       Output: /sensing/lidar/top/pointcloud  (Autoware contract)
  -->
  <include file="$(find-pkg-share m8_sensor_kit_launch)/launch/pointcloud_preprocessor.launch.py">
    <arg name="base_frame"   value="$(var base_frame)"/>
    <arg name="lidar_frame"  value="$(var lidar_frame_id)"/>
    <arg name="input_topic"  value="/sensing/lidar/top/pointcloud_raw"/>
    <arg name="output_topic" value="/sensing/lidar/top/pointcloud"/>
  </include>

</launch>
